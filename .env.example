# Google Apps Script web app URL (from Deploy → New deployment)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google OAuth Client ID (console.cloud.google.com → APIs & Services → Credentials)
# Its "Authorized JavaScript origins" must include wherever this app is hosted.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
